<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
    <TextView android:layout_marginTop="-120dp" android:text="Information Profile" android:fontFamily="@font/roboto_bold" style="@style/textViewStyle"/>
    <de.hdodenhof.circleimageview.CircleImageView android:id="@+id/imtAvataProfileViewInforActivity" android:layout_width="200dp" android:layout_height="200dp" android:layout_marginBottom="20dp" android:src="@drawable/img_default"/>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:textSize="22sp" android:textColor="#0b8e8d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email: " android:fontFamily="@font/roboto_medium" android:paddingStart="20dp"/>
        <TextView android:textSize="22sp" android:textColor="#0b8e8d" android:id="@+id/InforEmailViewInforActivity" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Email: " android:fontFamily="@font/roboto_regular" android:paddingEnd="20dp"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:textSize="22sp" android:textColor="#0b8e8d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Full name: " android:fontFamily="@font/roboto_medium" android:paddingStart="20dp"/>
        <TextView android:textSize="22sp" android:textColor="#0b8e8d" android:id="@+id/InforFullNameViewInforActivity" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Full name: " android:fontFamily="@font/roboto_regular" android:paddingEnd="20dp"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:textSize="22sp" android:textColor="#0b8e8d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Birth Day: " android:fontFamily="@font/roboto_medium" android:paddingStart="20dp"/>
        <TextView android:textSize="22sp" android:textColor="#0b8e8d" android:id="@+id/InforBirthDayViewInforActivity" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Birth Day: " android:fontFamily="@font/roboto_regular" android:paddingEnd="20dp"/>
    </LinearLayout>
</LinearLayout>
